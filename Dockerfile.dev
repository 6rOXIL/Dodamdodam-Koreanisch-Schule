# 개발 환경용 Dockerfile
FROM node:24.13.0-alpine

WORKDIR /app

# 패키지 매니저 캐시를 위한 설정
RUN apk add --no-cache libc6-compat

# package 파일 복사
COPY package.json package-lock.json ./

# 의존성 설치
RUN npm ci

# 소스 코드는 docker-compose에서 볼륨으로 마운트되므로 여기서는 복사하지 않음

EXPOSE 3000

ENV PORT 3000
ENV HOSTNAME "0.0.0.0"

# Entrypoint: lockfile이 바뀌면 node_modules 볼륨에 npm ci 재실행
RUN echo '#!/bin/sh' > /entrypoint.sh && \
    echo 'LOCK_STAMP="/app/node_modules/.package-lock.sha"' >> /entrypoint.sh && \
    echo 'LOCK_SHA=$(sha256sum package-lock.json 2>/dev/null | cut -d" " -f1)' >> /entrypoint.sh && \
    echo 'if [ ! -d "node_modules" ] || [ -z "$(ls -A node_modules 2>/dev/null)" ] || [ ! -f "$LOCK_STAMP" ] || [ "$(cat "$LOCK_STAMP" 2>/dev/null)" != "$LOCK_SHA" ]; then' >> /entrypoint.sh && \
    echo '  echo "Installing dependencies..."' >> /entrypoint.sh && \
    echo '  npm ci' >> /entrypoint.sh && \
    echo '  echo "$LOCK_SHA" > "$LOCK_STAMP"' >> /entrypoint.sh && \
    echo 'fi' >> /entrypoint.sh && \
    echo 'exec "$@"' >> /entrypoint.sh && \
    chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]

# 개발 서버 실행
CMD ["npm", "run", "dev"]
